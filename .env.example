# ── Logos Blockchain Node — environment variables ────────────────────────────
# Copy this file to .env and adjust as needed.
# Lines starting with # are comments and are ignored.

# Space-separated bootstrap peer multiaddrs for the devnet.
# Update these when a new node release is published.
BOOTSTRAP_PEERS=/ip4/65.109.51.37/udp/3000/quic-v1/p2p/12D3KooWL7a8LBbLRYnabptHPFBCmAs49Y7cVMqvzuSdd43tAJk8 /ip4/65.109.51.37/udp/3001/quic-v1/p2p/12D3KooWPLeAcachoUm68NXGD7tmNziZkVeMmeBS5NofyukuMRJh /ip4/65.109.51.37/udp/3002/quic-v1/p2p/12D3KooWKFNe4gS5DcCcRUVGdMjZp3fUWu6q6gG5R846Ui1pccHD /ip4/65.109.51.37/udp/3003/quic-v1/p2p/12D3KooWAnriLgXyQnGTYz1zPWPkQL3rthTKYLzuAP7MMnbgsxzR

# TCP port for the node's internal HTTP API.
# Do NOT expose this port publicly — dashboard.py proxies it internally.
API_PORT=8080

# Directory inside the container for config and chain state.
# Matches the named volume mount in docker-compose.yml.
DATA_DIR=/data

# Web dashboard port (mapped to host port 3001 in docker-compose.yml).
PORT=3001

# Same as API_PORT — used by dashboard.py to reach the node API.
NODE_API_PORT=8080

# Optional: set to enable HTTP basic auth on the dashboard.
# Username will be "admin". Leave empty for public access.
DASHBOARD_PASSWORD=

# Optional: your domain name, used by Caddy for automatic HTTPS.
# Only needed if you uncomment the caddy service in docker-compose.yml.
# DOMAIN=node.example.com
